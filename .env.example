# Twitter/X credentials
TWITTER_USERNAME=your_handle   # required — used to build tweet URLs

# LLM API keys (only needed if using --filter)
# Set whichever provider you want to use — you don't need all three.

# OpenAI — get key at platform.openai.com
OPENAI_API_KEY=sk-...

# Anthropic — get key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — get key at openrouter.ai (has a free tier)
OPENROUTER_API_KEY=sk-or-...
